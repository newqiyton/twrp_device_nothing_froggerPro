service vendor.gatekeeper-qti /vendor/bin/hw/android.hardware.gatekeeper-service-qti
    user system
    group system
    setenv LD_LIBRARY_PATH /system/lib64:/vendor/lib64:/vendor/lib64/hw:/bin
    seclabel u:r:recovery:s0
    disabled
